{
  "name": "parallax-display",
  "version": "0.1.0",
  "description": "Head-tracking parallax 3D display engine using webcam-based eye tracking",
  "type": "module",
  "main": "./dist/parallax-display.umd.cjs",
  "module": "./dist/parallax-display.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/parallax-display.js",
      "require": "./dist/parallax-display.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "license": "MIT"
}
